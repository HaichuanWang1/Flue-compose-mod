#version 100
precision mediump float;
precision highp int;

uniform mediump sampler2D u_tex0;
uniform mediump sampler2D u_tex1;

varying highp vec2 v_texCoord;
varying highp vec4 v_color;

void main()
{
    highp vec4 texColor = vec4(texture2D(u_tex0, v_texCoord).xyz, texture2D(u_tex1, v_texCoord).x);
    highp float _36 = texColor.w;
    highp vec4 _37 = texColor;
    highp vec3 _39 = _37.xyz * _36;
    texColor.x = _39.x;
    texColor.y = _39.y;
    texColor.z = _39.z;
    gl_FragData[0] = v_color * texColor;
}

