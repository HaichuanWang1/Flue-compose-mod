#version 100
precision mediump float;
precision highp int;

struct fs_ub
{
    highp float u_1;
};

uniform fs_ub _25;

uniform mediump sampler2D u_tex0;

varying highp vec2 v_texCoord;
varying highp vec4 v_color;

void main()
{
    highp vec4 color1 = texture2D(u_tex0, v_texCoord);
    highp vec3 color2 = vec3((sin(_25.u_1) + 1.0) / 2.0, v_texCoord.x, v_texCoord.y);
    highp float a = color1.w * v_color.w;
    gl_FragData[0] = vec4(color2 * a, a);
}

