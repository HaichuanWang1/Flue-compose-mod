#version 100
precision mediump float;
precision highp int;

struct fs_ub
{
    highp vec4 u_textColor;
};

uniform fs_ub _15;

uniform mediump sampler2D u_tex0;

varying highp vec4 v_color;
varying highp vec2 v_texCoord;

void main()
{
    gl_FragData[0] = v_color * vec4(_15.u_textColor.xyz, _15.u_textColor.w * texture2D(u_tex0, v_texCoord).x);
}

