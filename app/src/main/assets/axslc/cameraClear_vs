#version 100

struct vs_ub
{
    float depth;
};

uniform vs_ub _20;

attribute vec4 a_position;
varying vec2 v_texCoord;
attribute vec2 a_texCoord;
varying vec4 v_color;
attribute vec4 a_color;

void main()
{
    gl_Position = a_position;
    gl_Position.z = _20.depth;
    gl_Position.w = 1.0;
    v_texCoord = a_texCoord;
    v_color = a_color;
}

