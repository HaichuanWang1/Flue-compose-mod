#version 100
precision mediump float;
precision highp int;

struct fs_ub
{
    highp vec4 u_color;
};

uniform fs_ub _26;

uniform mediump sampler2D u_tex0;

varying highp vec2 v_texCoord;
varying highp vec4 v_color;

void main()
{
    gl_FragData[0] = (texture2D(u_tex0, v_texCoord) * v_color) * _26.u_color;
}

