#version 100
precision mediump float;
precision highp int;

struct fs_ub
{
    highp vec4 u_effectColor;
    highp vec4 u_textColor;
    int u_labelPass;
};

uniform fs_ub _33;

uniform mediump sampler2D u_tex0;

varying highp vec2 v_texCoord;
varying highp vec4 v_color;

void main()
{
    highp vec4 texColor = texture2D(u_tex0, v_texCoord);
    highp float fontAlpha = texColor.w;
    highp float outlineAlpha = texColor.x;
    if (_33.u_labelPass == 0)
    {
        gl_FragData[0] = v_color * vec4(_33.u_textColor.xyz, _33.u_textColor.w * fontAlpha);
    }
    else
    {
        if (_33.u_labelPass == 1)
        {
            gl_FragData[0] = v_color * vec4(_33.u_effectColor.xyz, (_33.u_effectColor.w * outlineAlpha) * (1.0 - fontAlpha));
        }
        else
        {
            gl_FragData[0] = v_color * vec4(_33.u_effectColor.xyz, _33.u_effectColor.w * outlineAlpha);
        }
    }
}

